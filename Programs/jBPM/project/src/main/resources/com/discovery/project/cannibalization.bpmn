        <bpmn2:script>jep.JepConfig jepConfig = (jep.JepConfig) kcontext.getVariable(&quot;jepConfig&quot;);
jep.SubInterpreter subInterp = (jep.SubInterpreter) kcontext.getVariable(&quot;subInterp&quot;);
jepConfig.setSharedModules(null);
kcontext.setVariable(&quot;subInterp&quot;,null);
kcontext.setVariable(&quot;jepConfig&quot;,null);

java.lang.String script100 = java.lang.String.join(&quot;\n&quot;,
&quot;if 'qiskit' in sys.modules:&quot;,
&quot;    del sys.modules['qiskit']&quot;,
&quot;    gc.collect()&quot;,
&quot;if 'qiskit_ibm_runtime' in sys.modules:&quot;,
&quot;    del sys.modules['qiskit_ibm_runtime']&quot;,
&quot;    gc.collect()&quot;,
&quot;if 'qiskit_aer' in sys.modules:&quot;,
&quot;    del sys.modules['qiskit_aer']&quot;,
&quot;    gc.collect()&quot;,
&quot;if 'azure.quantum' in sys.modules:&quot;,
&quot;    del sys.modules['azure.quantum']&quot;,
&quot;    gc.collect()&quot;,
&quot;if 'azure.identity' in sys.modules:&quot;,
&quot;    del sys.modules['azure.identity']&quot;,
&quot;    gc.collect()&quot;,
&quot;if 'azure.mgmt.resource.resources' in sys.modules:&quot;,
&quot;    del sys.modules['azure.mgmt.resource.resources']&quot;,
&quot;    gc.collect()&quot;,
&quot;if 'threading' in sys.modules:&quot;,
&quot;    del sys.modules['threading']&quot;,
&quot;    gc.collect()&quot;);

subInterp.set(&quot;script100&quot;, script100);
subInterp.eval(&quot;exec(script100)&quot;);

subInterp.close();
subInterp=null;
System.gc();
System.out.println(&quot;####### Finished Sub Process 2: cannibalization.bpmn #######&quot;);</bpmn2:script>
      </bpmn2:scriptTask>
      <bpmn2:scriptTask id="ScriptTask_6" name="Setup" scriptFormat="http://www.java.com/java">
        <bpmn2:extensionElements>
          <tns:metaData name="elementname">
            <tns:metaValue><![CDATA[Setup]]></tns:metaValue>
          </tns:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>SequenceFlow_20</bpmn2:incoming>
        <bpmn2:outgoing>SequenceFlow_10</bpmn2:outgoing>
        <bpmn2:script>System.out.println(&quot;####### Starting Sub Process 2: cannibalization.bpmn #######&quot;);
kcontext.setVariable(&quot;count&quot;, iterations.getNumber());
kcontext.setVariable(&quot;size&quot;, dimension.getSize());
kcontext.setVariable(&quot;cannibals&quot;, products.getCannibals());
kcontext.setVariable(&quot;i&quot;, 1);
jep.JepConfig jepConfig = new jep.JepConfig();
//jepConfig.addSharedModules(&quot;warnings&quot;);
jepConfig.addSharedModules(&quot;numpy&quot;);
jepConfig.addSharedModules(&quot;pandas&quot;);
jepConfig.addSharedModules(&quot;matplotlib&quot;);
jepConfig.addSharedModules(&quot;seaborn&quot;);
jepConfig.addSharedModules(&quot;psycopg2&quot;);
//jepConfig.addSharedModules(&quot;json&quot;);
//jepConfig.addSharedModules(&quot;qiskit&quot;);
//jepConfig.addSharedModules(&quot;qiskit_ibm_runtime&quot;);
//jepConfig.addSharedModules(&quot;qiskit_aer&quot;);
//jepConfig.addSharedModules(&quot;azure.quantum&quot;);
//jepConfig.addSharedModules(&quot;azure.quantum.qiskit&quot;);
//jepConfig.addSharedModules(&quot;azure.identity&quot;);
//jepConfig.addSharedModules(&quot;azure.mgmt.resource.resources&quot;);
jep.SubInterpreter subInterp = new jep.SubInterpreter(jepConfig);

java.lang.Integer size = (java.lang.Integer) kcontext.getVariable(&quot;size&quot;);
subInterp.set(&quot;size&quot;, size);
subInterp.eval(&quot;size&quot;);

java.lang.String cannibals = (java.lang.String) kcontext.getVariable(&quot;cannibals&quot;);
subInterp.set(&quot;cannibals&quot;, cannibals);
subInterp.eval(&quot;cannibals&quot;);

java.lang.String script = java.lang.String.join(&quot;\n&quot;,
&quot;import warnings&quot;,
&quot;warnings.filterwarnings('ignore')&quot;,
&quot;import sys&quot;,
&quot;import gc&quot;,
&quot;import numpy as np&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP00.txt', [sys.version_info], fmt = '%s')&quot;,
&quot;import pandas as pd&quot;,
&quot;import psycopg2&quot;,
&quot;#import qiskit_ibm_runtime&quot;,
&quot;conn=psycopg2.connect('host=127.0.0.1 port=5432 dbname=cannibalization user=postgres password=pAsSwOrD target_session_attrs=read-write')&quot;,
&quot;Data=pd.read_sql('SELECT * FROM public.mavenanalyticsdata',conn)&quot;,
&quot;Data=Data[~Data['REWARD_AMOUNT'].isna()]&quot;,
&quot;Data0=Data.drop(['CUSTOMER_ID','EVENT','IS_AMOUNT','IS_REWARD','IS_OTHER','AMOUNT_AMOUNT'],axis=1)&quot;,
&quot;Data0=Data0.groupby(['TIME','OFFER_ID'])['REWARD_AMOUNT'].agg('sum').unstack()&quot;,
&quot;corrmat=Data0.corr()&quot;,
&quot;corrmat[corrmat.columns] = 0&quot;,
&quot;cannibals=cannibals.split('*')&quot;,
&quot;cannibals=[x for x in cannibals if x != 'YYYY']&quot;,
&quot;if len(cannibals)>0:&quot;,
&quot;    size=len(cannibals)&quot;,
&quot;import os&quot;,
&quot;import subprocess&quot;,
&quot;pro=subprocess.run(['python', 'C:/Users/serge/eclipse-workspace/Java_Lab/src/azure_quantum.py', str(size*size)], shell=False, capture_output=True)&quot;,
&quot;result=pro.stdout.decode('utf-8')&quot;,
&quot;dim=result[result.find('{')+1 : result.find('}')]&quot;,
&quot;result=result[result.find('[[') : result.find(']]')+2]&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP01.txt', [result], fmt = '%s')&quot;);
subInterp.set(&quot;script&quot;, script);
subInterp.eval(&quot;exec(script)&quot;);

//java.lang.String values = (java.lang.String) subInterp.getValue(&quot;output1&quot;);
//kcontext.setVariable(&quot;values&quot;,values);
//java.lang.String errors = (java.lang.String) subInterp.getValue(&quot;output2&quot;);
//kcontext.setVariable(&quot;errors&quot;,errors);
java.lang.String dim = (java.lang.String) subInterp.getValue(&quot;dim&quot;);
java.lang.String result = (java.lang.String) subInterp.getValue(&quot;result&quot;);
//System.out.println(dim);
System.out.println(result);

kcontext.setVariable(&quot;subInterp&quot;,subInterp);
kcontext.setVariable(&quot;jepConfig&quot;,jepConfig);</bpmn2:script>
      </bpmn2:scriptTask>
      <bpmn2:sequenceFlow id="SequenceFlow_10" tns:priority="1" sourceRef="ScriptTask_6" targetRef="ScriptTask_4"/>
      <bpmn2:scriptTask id="ScriptTask_5" name="Action" scriptFormat="http://www.java.com/java">
        <bpmn2:extensionElements>
          <tns:metaData name="elementname">
            <tns:metaValue><![CDATA[Action]]></tns:metaValue>
          </tns:metaData>
        </bpmn2:extensionElements>
        <bpmn2:incoming>SequenceFlow_12</bpmn2:incoming>
        <bpmn2:outgoing>SequenceFlow_5</bpmn2:outgoing>
        <bpmn2:script>System.out.println(&quot;count = &quot; + kcontext.getVariable(&quot;count&quot;));
System.out.println(&quot;i = &quot; + kcontext.getVariable(&quot;i&quot;));
jep.JepConfig jepConfig = (jep.JepConfig) kcontext.getVariable(&quot;jepConfig&quot;);
jep.SubInterpreter subInterp = (jep.SubInterpreter) kcontext.getVariable(&quot;subInterp&quot;);

subInterp.set(&quot;i&quot;, kcontext.getVariable(&quot;i&quot;));

java.lang.String script = java.lang.String.join(&quot;\n&quot;,
&quot;corrmat=pd.DataFrame()&quot;,
&quot;for y in Data['TIME'].unique():&quot;,
&quot;    t=np.random.choice(Data['TIME'].unique(),7,replace=True)&quot;,
&quot;    Data1=Data.loc[Data['TIME'].isin(t)]&quot;,
&quot;    Data1=Data1.drop(['CUSTOMER_ID','EVENT','IS_AMOUNT','IS_REWARD','IS_OTHER','AMOUNT_AMOUNT'],axis=1)&quot;,
&quot;    Data1=Data1.groupby(['TIME','OFFER_ID'])['REWARD_AMOUNT'].agg('sum').unstack()&quot;,
&quot;    corrmat_tmp=Data1.corr()&quot;,
&quot;    corrmat_tmp.columns.name='OFFER'&quot;,
&quot;    corrmat=corrmat.add(corrmat_tmp, fill_value=0)&quot;,
&quot;corrmat_mean=corrmat/len(Data['TIME'].unique())&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10A.txt', corrmat_mean, fmt = '%s')&quot;,
&quot;dim = int(dim)&quot;,
&quot;import math&quot;,
&quot;corrmat_mean_sliced=corrmat_mean.iloc[:int(math.sqrt(dim)),:int(math.sqrt(dim))]&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10B.txt', corrmat_mean_sliced, fmt = '%s')&quot;,
&quot;matrix1=result.replace('. ', '.0000 ')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10C.txt', [matrix1], fmt = '%s')&quot;,
&quot;matrix2=matrix1.replace('  ', ' ')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10D.txt', [matrix2], fmt = '%s')&quot;,
&quot;matrix3=matrix2.replace('  ', ' ')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP1E.txt', [matrix3], fmt = '%s')&quot;,
&quot;matrix4=matrix3.replace('  ', ' ')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10F.txt', [matrix4], fmt = '%s')&quot;,
&quot;matrix5=matrix4.replace('  ', ' ')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10G.txt', [matrix5], fmt = '%s')&quot;,
&quot;matrix6=matrix5.replace('  ', ' ')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10H.txt', [matrix6], fmt = '%s')&quot;,
&quot;matrix7=matrix6.replace(' [', ',[')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10I.txt', [matrix7], fmt = '%s')&quot;,
&quot;matrix8=matrix7.replace(' ]', ']')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10J.txt', [matrix8], fmt = '%s')&quot;,
&quot;matrix9=matrix8.replace(' ', ', ')&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10K.txt', [matrix9], fmt = '%s')&quot;,
&quot;import json&quot;,
&quot;disturbance=json.loads(matrix9)&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP10L.txt', disturbance, fmt = '%s')&quot;,
&quot;corrmat_mean_sliced=corrmat_mean_sliced.reset_index(drop=True)&quot;,
&quot;corrmat_mean_sliced=corrmat_mean_sliced.T.reset_index(drop=True).T&quot;,
&quot;disturbance=pd.DataFrame(disturbance)&quot;,
&quot;disturbance=disturbance.reset_index(drop=True)&quot;,
&quot;disturbance=disturbance.T.reset_index(drop=True).T&quot;,
&quot;corrmat_disturbed=(corrmat_mean_sliced.add(disturbance))/2&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP11.txt', corrmat_disturbed, fmt = '%s')&quot;,
&quot;f=plt.figure()&quot;,
&quot;sns.heatmap(corrmat_disturbed, xticklabels=corrmat_disturbed.columns, yticklabels=corrmat_disturbed.columns)&quot;,
&quot;plt.title('Correlation analysis of category sales volumes (by year/month)')&quot;,
&quot;f.savefig('C:/Users/serge/eclipse-workspace/Java_Lab/src/CANNIBALIZATION_C'+str(i)+'.png')&quot;,
&quot;plt.close(f)&quot;,
&quot;#corrmat=Data0.corr()&quot;,
&quot;#matrix = quantum_random_matrix(len(corrmat.columns))&quot;,
