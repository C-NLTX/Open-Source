jep.SubInterpreter subInterp = (jep.SubInterpreter) kcontext.getVariable(&quot;subInterp&quot;);

java.lang.String script = java.lang.String.join(&quot;\n&quot;,
&quot;import psycopg2.extras as extras&quot;,
&quot;#corrmat_disturbed=pd.DataFrame(corrmat_disturbed, columns=list(range(1,int(math.sqrt(dim))+1)))&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP20.txt', corrmat_disturbed, fmt = '%s')&quot;,
&quot;tuples = [tuple(row) for row in corrmat_disturbed.itertuples(index=False)]&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP21.txt', tuples, fmt = '%s')&quot;,
&quot;cols = ','.join(chr(i)+' FLOAT' for i in range(ord('A'), ord('A') + int(math.sqrt(dim))))&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP22.txt', [cols], fmt = '%s')&quot;,
&quot;cursor = conn.cursor()&quot;,
&quot;cursor.execute('DROP TABLE IF EXISTS public.mavenanalyticscorrmat')&quot;,
&quot;cursor.execute('CREATE TABLE public.mavenanalyticscorrmat ('+cols+')')&quot;,
&quot;cursor.close()&quot;,
&quot;conn.commit()&quot;,
&quot;cols = ','.join(chr(i) for i in range(ord('A'), ord('A') + int(math.sqrt(dim))))&quot;,
&quot;np.savetxt('C:/Users/serge/eclipse-workspace/Java_Lab/src/STAMP23.txt', [cols], fmt = '%s')&quot;,
&quot;query = 'INSERT INTO %s(%s) VALUES %%s' % ('public.mavenanalyticscorrmat', cols)&quot;,
&quot;cursor = conn.cursor()&quot;,
&quot;extras.execute_values(cursor, query, tuples)&quot;,
&quot;conn.commit()&quot;);

subInterp.set(&quot;script&quot;, script);
subInterp.eval(&quot;exec(script)&quot;);

